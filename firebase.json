{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/login",
        "destination": "/login.html"
      },
      {
        "source": "/dashboard",
        "destination": "/dashboard.html"
      },
      {
        "source": "/dashboard/intro",
        "destination": "/dashboard-intro.html"
      },
      {
        "source": "/dashboard/projects",
        "destination": "/dashboard-projects.html"
      }
    ],
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
