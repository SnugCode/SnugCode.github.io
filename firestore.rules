rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /portfolio/content {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "snadith2003@gmail.com";
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
